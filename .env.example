# ═══════════════════════════════════════════════════════════════
# CrossBorder Analytics — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# The application reads DATA_SOURCE to decide which adapter to use.
# ───────────────────────────────────────────────────────────────

# Data source selection
#   mock         — Simulated data (default, works out of the box)
#   csv          — Import real data from CSV files
#   amazon_spapi — Amazon Selling Partner API (requires developer account)
#   tiktok       — TikTok Shop Partner API
#   shopee       — Shopee Open Platform API
DATA_SOURCE=mock

# ───────────────────────────────────────────────────────────────
# Amazon SP-API (Selling Partner API)
# ───────────────────────────────────────────────────────────────
# Requirements:
#   - Amazon Seller Central 专业销售账户
#   - 注册为 Amazon 开发者: https://developer.amazon.com
#   - 创建 SP-API 应用 → 获取 LWA credentials
#   - 审核周期: 2-4 周
# See: docs/API_SETUP.md#amazon
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# ───────────────────────────────────────────────────────────────
# TikTok Shop Partner API
# ───────────────────────────────────────────────────────────────
# Requirements:
#   - TikTok Shop 商家账号
#   - 申请 Partner API: https://partner.tiktokshop.com
#   - 审核周期: 1-2 周
# See: docs/API_SETUP.md#tiktok
TIKTOK_PARTNER_KEY=
TIKTOK_PARTNER_SECRET=
TIKTOK_SHOP_ID=

# ───────────────────────────────────────────────────────────────
# Shopee Open Platform API
# ───────────────────────────────────────────────────────────────
# Requirements:
#   - Shopee 卖家中心账号
#   - 注册 Open Platform: https://open.shopee.com
#   - 创建应用获取 Partner ID & Key
#   - 审核周期: 1-3 天
# See: docs/API_SETUP.md#shopee
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# ───────────────────────────────────────────────────────────────
# CSV Import
# ───────────────────────────────────────────────────────────────
# Set DATA_SOURCE=csv and place CSV files in this directory.
# File naming: {platform_code}_{YYYY-MM-DD}.csv
# Example: amazon_2026-06-16.csv
# See: docs/CSV_UPLOAD.md
CSV_DATA_PATH=./csv_data/
